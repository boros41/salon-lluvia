@model Mvc.Models.Gallery.Image

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Image</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.HairProfile.Gender)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.HairProfile.Gender)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HairProfile.HairStyles)
        </dt>
        <dd class="col-sm-10">
            @string.Join(", ", Model.HairProfile.HairStyles.Select(hairstyle => hairstyle.Style))
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HairProfile.HairColors)
        </dt>
        <dd class="col-sm-10">
            @string.Join(", ", Model.HairProfile.HairColors.Select(hairstyle => hairstyle.Color))
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-controller="Home" asp-action="Gallery" asp-area="">Back to Gallery</a>
    </form>
</div>
