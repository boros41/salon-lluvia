<!DOCTYPE html>
<html lang="es">
<head>
    <title>@ViewData["Title"] - Salon Lluvia</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="~/favicon.svg" rel="icon" type="image/svg+xml">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Playfair+Display:wght@500&family=Work+Sans&display=swap"
          rel="stylesheet" asp-append-version="true">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet" asp-append-version="true">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet" asp-append-version="true">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/animate.css/animate.min.css" rel="stylesheet" asp-append-version="true">
    <link href="~/lib/lightbox/css/lightbox.min.css" rel="stylesheet" asp-append-version="true">
    <link href="~/lib/glidejs/glide/dist/css/glide.core.min.css" rel="stylesheet" asp-append-version="true">
    <link href="~/lib/glidejs/glide/dist/css/glide.theme.min.css" rel="stylesheet" asp-append-version="true">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true">

    <!-- Pages Stylesheet -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
    @await RenderSectionAsync("Styles", false)
</head>
<body>
    <partial name="_LoadingSpinnerPartial"/>

    <header class="sticky-top">
        <partial name="_navBarPartial" />
    </header>

    <main role="main">
        <partial name="_toastMessagePartial"/>
        @RenderBody()
    </main>

    <footer>
        <partial name="_footerPartial" />
    </footer>

    <!-- JavaScript Libraries -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/jquery-validate/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/countUp/dist/countUp.umd.js"></script>
    <script src="~/lib/lightbox/js/lightbox.min.js"></script>
    <script src="~/lib/glidejs/glide/dist/glide.min.js"></script>
    @await RenderSectionAsync("LibPhoneNumberJS", false)

    <!-- Template Javascript -->
    <script src="~/js/main.js" asp-append-version="true"></script>
    
    <!-- Page Scripts-->
    <script src="~/js/toast-message.js" asp-append-version="true"></script>
    @await RenderSectionAsync("AppointmentFormJS", false)
    @await RenderSectionAsync("Gallery", false)
    @await RenderSectionAsync("Index", false)
    </body>
</html>