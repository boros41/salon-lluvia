@model Mvc.Models.Gallery.ViewModels.ImageViewModel
@{
    ViewData["Title"] = "Gallery";
}

<partial name="_breadcrumbPartial" />

<!-- Gallery Start -->

<div class="container gallery py-5">
    <div class="text-center wow animate__fadeInLeft" data-wow-delay="0.2s">
        <h1 class="font-dancing-script text-primary">Gallery</h1>
        <h1 class="mb-4">Explore Our Gallery</h1>
    </div>
    
    @*Admin Upload Image Modal*@
    @using Microsoft.AspNetCore.Identity
    
@using Mvc.Models.Gallery
@using Mvc.Models.Gallery.ViewModels
@inject SignInManager<User> SignInManager
    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
    {
        <div class="row justify-content-center mb-3">
            <button type="button" class="btn btn-primary w-auto" data-bs-toggle="modal" data-bs-target="#upload-image-modal">
                Upload Image
            </button>
        </div>

        <div class="modal fade" id="upload-image-modal" tabindex="-1" aria-labelledby="upload-image-modal" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">Upload image</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-controller="Home" asp-action="Gallery" method="post">
                        <div class="modal-body g-0">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col">
                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col">
                                        <span asp-validation-for="Image" class="text-danger"></span><br />
                                        <label asp-for="Image" class="form-label fw-bold"></label>
                                        <input asp-for="Image" type="file" class="form-control"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col">
                                        <span asp-validation-for="Gender" class="text-danger"></span><br />
                                        <label asp-for="Gender" class="form-label fw-bold"></label><br />

                                        <input asp-for="Gender" id="female" class="form-check-input" name="Gender" type="radio" value="F" />
                                        <label for="female" class="form-check-label">Female</label>
                                        <input asp-for="Gender" id="male" class="form-check-input" name="Gender" type="radio" value="M"/>
                                        <label for="male" class="form-check-label">Male</label>
                                    </div>
                                </div>
                                
                                @{
                                    var inputClassAttribute = new Dictionary<string, object>() { { "class", "form-check-input" } };
                                    var labelClassAttribute = new Dictionary<string, object>() { { "class", "form-check-label" } };
                                }
                                <div class="row">
                                    <div class="col">
                                        @*Hair type checkboxes such as "peinado"*@
                                        <span asp-validation-for="HairTypes" class="text-danger"></span><br/>
                                        <label asp-for="HairTypes" class="form-label fw-bold"></label><br/>

                                        @for (int i = 0; i < Model.HairTypes.Count; i++)
                                        {
                                            string label = char.ToUpper(Model.HairTypes[i].Type[0]) + Model.HairTypes[i].Type[1..].ToLower();
                                            
                                            @Html.CheckBoxFor(model => model.HairTypes[i].IsChecked, inputClassAttribute)
                                            @Html.LabelFor(model => model.HairTypes[i].IsChecked, label, labelClassAttribute)
                                            <input asp-for="HairTypes[i].Type" type="hidden"/>
                                        }
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col">
                                        @*Hair color checkboxes*@
                                        <span asp-validation-for="HairColors" class="text-danger"></span><br/>
                                        <label asp-for="HairColors" class="form-label fw-bold"></label><br />

                                        @for (int i = 0; i < Model.HairColors.Count; i++)
                                        {
                                            string label = char.ToUpper(Model.HairColors[i].Color[0]) + Model.HairColors[i].Color[1..].ToLower();
                                            
                                            @Html.CheckBoxFor(model => model.HairColors[i].IsChecked, inputClassAttribute)
                                            @Html.LabelFor(model => model.HairColors[i].IsChecked, label, labelClassAttribute)
                                            <input asp-for="HairColors[i].Color" type="hidden" />
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="submit" class="btn btn-primary">Save changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="row g-2" data-masonry='{"percentPosition": true }'>
        <div class="col-sm-6 col-lg-3 wow fadeIn">
            <div class="card">
                <div class="gallery-item">
                    <img src="~/img/gallery-1.jpg" class="card-img-top" alt=""/>
                    <div class="gallery-icon">
                        <a href="~/img/gallery-1.jpg" class="btn btn-primary btn-lg-square" data-lightbox="Gallery-1">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">A nice peinado</p>
                </div>
            </div>
        </div>
