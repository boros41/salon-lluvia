        </div>
        <div class="col-sm-6 col-lg-3 wow fadeIn">
            <div class="card">
                <div class="gallery-item">
                    <img src="~/img/gallery-6.jpg" class="card-img-top" alt=""/>
                    <div class="gallery-icon">
                        <a href="~/img/gallery-6.jpg" class="btn btn-primary btn-lg-square" data-lightbox="Gallery-6">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
