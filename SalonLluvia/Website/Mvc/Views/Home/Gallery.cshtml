            <div class="card">
                <div class="gallery-item">
                    <img src="~/img/gallery-5.jpg" class="card-img-top" alt="" />
                    <div class="gallery-icon">
                        <a href="~/img/gallery-5.jpg" class="btn btn-primary btn-lg-square" data-lightbox="Gallery-5">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">A nice peinado</p>
