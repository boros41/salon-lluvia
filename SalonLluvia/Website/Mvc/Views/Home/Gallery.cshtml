                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">A nice peinado</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 wow fadeIn">
            <div class="card">
                <div class="gallery-item">
                    <img src="~/img/gallery-3.jpg" class="card-img-top" alt="" />
                    <div class="gallery-icon">
                        <a href="~/img/gallery-3.jpg" class="btn btn-primary btn-lg-square" data-lightbox="Gallery-3">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">A nice peinado</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 wow fadeIn">
            <div class="card">
                <div class="gallery-item">
                    <img src="~/img/gallery-4.jpg" class="card-img-top" alt="" />
                    <div class="gallery-icon">
                        <a href="~/img/gallery-4.jpg" class="btn btn-primary btn-lg-square" data-lightbox="Gallery-4">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">A nice peinado</p>
