@model LoginViewModel
@{
    ViewBag.Title = "Login";
}

<div class="container">
    <div class="row text-center">
        <h1 class="col">Login</h1>
    </div>
    
    <div class="row justify-content-center">
        <div asp-validation-summary="ModelOnly" class="text-danger col-md-6"></div>
    </div>
    <form method="post" asp-action="LogIn" asp-route-returnUrl="@Model.ReturnUrl">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
        </div>
        <div class="row mb-2 justify-content-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Username" class="form-control" placeholder="Username">
                    <label asp-for="Username">Username</label>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-6">
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
        </div>
        <div class="row mb-2 justify-content-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password">
                    <label asp-for="Password">Password</label>
                </div>
            </div>
        </div>

        <div class="row mb-2 justify-content-center">
            <div class="col-md-6">
                <input type="checkbox" title="Remember Me" asp-for="RememberMe"
                       class="form-check-inline"/>
                <label asp-for="RememberMe"></label>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <button type="submit" class="btn btn-primary">Log In</button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-primary">Cancel</a>
            </div>
        </div>
    </form>
</div>